#!/usr/bin/env bash
set -euxo pipefail

APP_VERSION="26.616.32156"
APP_ZIP_NAME="Codex-darwin-arm64-$APP_VERSION.zip"
APP_ZIP_URL="https://persistent.oaistatic.com/codex-app-prod/$APP_ZIP_NAME"
CODEX_APP_CACHE_DIR="${CODEX_APP_CACHE_DIR:-"$PWD/.cache/codex-app"}"
HOSTED_CODEX_APP_ZIP="$CODEX_APP_CACHE_DIR/$APP_ZIP_NAME"
TEMP_ZIP=""

cleanup_temp_zip() {
  if [[ -n "$TEMP_ZIP" ]]; then
    rm -f "$TEMP_ZIP"
  fi
}

trap cleanup_temp_zip EXIT

mkdir -p "$CODEX_APP_CACHE_DIR"

if [[ ! -f "$HOSTED_CODEX_APP_ZIP" ]] || ! unzip -tq "$HOSTED_CODEX_APP_ZIP" >/dev/null; then
  TEMP_ZIP="$(mktemp "$HOSTED_CODEX_APP_ZIP.download.XXXXXX")"
  curl -fL -o "$TEMP_ZIP" "$APP_ZIP_URL"
  unzip -tq "$TEMP_ZIP" >/dev/null
  mv "$TEMP_ZIP" "$HOSTED_CODEX_APP_ZIP"
  TEMP_ZIP=""
fi

HOSTED_CODEX_APP_ZIP="$HOSTED_CODEX_APP_ZIP" bash ./scripts/prepare_asar
